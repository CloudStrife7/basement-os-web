---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalShell from '../components/TerminalShell.astro';
import TourEntry from '../components/TourEntry.astro';
import type { TourMission } from '../components/TourEntry.astro';

const missions: TourMission[] = [
  {
    id: 'sky-carps-star-wars-2025',
    title: 'SKY CARPS STAR WARS NIGHT',
    date: 'August 17, 2025',
    location: 'Wisconsin Rapids, WI',
    status: 'mission-complete',
    debrief: true,
    coverPhoto: '/images/tour/sky-carps-star-wars-2025/cover.jpg',
    photos: [
      '/images/tour/sky-carps-star-wars-2025/01.jpg',
      '/images/tour/sky-carps-star-wars-2025/02.jpg',
      '/images/tour/sky-carps-star-wars-2025/03.jpg',
    ],
    description: 'Star Wars Night with the Wisconsin Rapids Sky Carps. Suited up as Boba Fett.',
  },
];
---

<BaseLayout title="BASEMENT OS | Tour of Duty">
  <TerminalShell activeSection="tour">
    <div class="content-section active">
      <h2 class="section-header">C:\BASEMENT\TOUR.LOG</h2>

      <div class="mission-statement">
        <h3>Tour of Duty</h3>
        <p>Real-world deployments. IRL missions. Field reports from the field.</p>
      </div>

      <div class="separator">────────────────────────────────────────────────────────────────────</div>

      <!-- MISSION TIMELINE -->
      <div class="tour-timeline">
        {missions.map((mission) => (
          <TourEntry mission={mission} />
        ))}
      </div>

    </div>
  </TerminalShell>

  <!-- PHOTOBOOTH MODAL -->
  <div id="photobooth-modal" class="photobooth-overlay" role="dialog" aria-modal="true" aria-label="Photobooth">
    <div class="photobooth-inner">
      <button class="photobooth-close-btn" id="photobooth-close" aria-label="Close photobooth">
        [ESC] CLOSE
      </button>
      <div class="photobooth-strip" id="photobooth-strip">
        <!-- Polaroid frames injected by JS -->
      </div>
      <div class="photobooth-caption">
        <span class="photobooth-mission-title" id="photobooth-title"></span>
        <span class="photobooth-mission-meta" id="photobooth-meta"></span>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ missions }}>
  // Build a lookup map for fast access
  /** @type {Record<string, typeof missions[0]>} */
  const missionMap = {};
  missions.forEach((m) => { missionMap[m.id] = m; });

  const modal = document.getElementById('photobooth-modal');
  const strip = document.getElementById('photobooth-strip');
  const titleEl = document.getElementById('photobooth-title');
  const metaEl = document.getElementById('photobooth-meta');
  const closeBtn = document.getElementById('photobooth-close');

  /** @param {string} missionId */
  function openPhotobooth(missionId) {
    const mission = missionMap[missionId];
    if (!mission || !strip || !titleEl || !metaEl || !modal) return;

    strip.innerHTML = '';

    mission.photos.forEach((src, i) => {
      const frame = document.createElement('div');
      frame.className = 'photobooth-polaroid';
      frame.style.setProperty('--rotation', `${(i % 2 === 0 ? 1 : -1) * (1 + (i % 3))}deg`);

      const img = document.createElement('img');
      img.src = src;
      img.alt = `${mission.title} — photo ${i + 1}`;
      img.loading = 'eager';

      const label = document.createElement('div');
      label.className = 'photobooth-polaroid-label';
      label.textContent = `${String(i + 1).padStart(2, '0')}`;

      frame.appendChild(img);
      frame.appendChild(label);
      strip.appendChild(frame);
    });

    titleEl.textContent = mission.title;
    metaEl.textContent = `${mission.date}  ·  ${mission.location}`;
    modal.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closePhotobooth() {
    modal?.classList.remove('active');
    document.body.style.overflow = '';
  }

  // Wire up each mission card
  document.querySelectorAll('.tour-mission').forEach((card) => {
    const id = card.getAttribute('data-mission-id');
    if (!id) return;

    card.addEventListener('click', () => openPhotobooth(id));
    card.addEventListener('keydown', (e) => {
      const ke = /** @type {KeyboardEvent} */ (e);
      if (ke.key === 'Enter' || ke.key === ' ') {
        ke.preventDefault();
        openPhotobooth(id);
      }
    });
  });

  // Close handlers
  closeBtn?.addEventListener('click', closePhotobooth);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closePhotobooth();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePhotobooth();
  });
</script>
