<script>
  document.addEventListener('astro:page-load', () => {
    // ─── BOOT SEQUENCE ───
    const bootScreen = document.getElementById('boot-screen');
    const mainTerminal = document.getElementById('main-terminal');
    const bootLines = document.querySelectorAll('.boot-line');

    if (!bootScreen || !mainTerminal) return;

    // Animate boot lines
    bootLines.forEach((line) => {
      const el = line as HTMLElement;
      const delay = parseInt(el.dataset.delay || '0', 10);
      setTimeout(() => {
        el.style.animationDelay = '0s';
        el.classList.add('visible');
        el.style.opacity = '1';
      }, delay);
    });

    // Skip boot on click/keypress
    let booted = false;
    function finishBoot() {
      if (booted) return;
      booted = true;
      bootScreen.style.display = 'none';
      mainTerminal.style.display = 'block';
      const input = document.getElementById('term-input') as HTMLInputElement | null;
      if (input) input.focus();
    }

    const autoBootDelay = setTimeout(finishBoot, 7000);

    function skipBoot() {
      clearTimeout(autoBootDelay);
      finishBoot();
    }

    bootScreen.addEventListener('click', skipBoot);
    document.addEventListener('keydown', function bootKey(e: KeyboardEvent) {
      if (!booted) {
        skipBoot();
        document.removeEventListener('keydown', bootKey);
      }
    });

    // ─── REBOOT BUTTON ───
    const rebootBtn = document.getElementById('pork-reboot');
    if (rebootBtn) {
      rebootBtn.addEventListener('click', () => {
        booted = false;
        mainTerminal.style.display = 'none';
        bootScreen.style.display = 'flex';
        bootLines.forEach((line) => {
          (line as HTMLElement).style.opacity = '0';
          line.classList.remove('visible');
        });
        // Re-trigger boot
        bootLines.forEach((line) => {
          const el = line as HTMLElement;
          const delay = parseInt(el.dataset.delay || '0', 10);
          setTimeout(() => {
            el.style.opacity = '1';
            el.classList.add('visible');
          }, delay);
        });
        setTimeout(finishBoot, 7000);
      });
    }

    // ─── UPTIME COUNTER ───
    const bootTime = Date.now();
    const uptimeEl = document.getElementById('pork-uptime');
    if (uptimeEl) {
      setInterval(() => {
        const elapsed = Math.floor((Date.now() - bootTime) / 1000);
        const mins = Math.floor(elapsed / 60);
        const secs = elapsed % 60;
        uptimeEl.textContent = `${mins}m ${secs}s (and counting)`;
      }, 1000);
    }

    // ─── INTERACTIVE TERMINAL ───
    const termInput = document.getElementById('term-input') as HTMLInputElement | null;
    const termOutput = document.getElementById('term-output');

    if (!termInput || !termOutput) return;

    const pigFacts = [
      "Pigs are among the smartest domesticated animals — smarter than dogs!",
      "A group of pigs is called a 'sounder'. A sounder investment? Porkbun domains.",
      "Pigs can run up to 11 mph. That's faster than some DNS propagation.",
      "Baby pigs are called piglets. Baby domains are called 'just registered on Porkbun'.",
      "Pigs have excellent long-term memory. They never forget a good domain deal.",
      "Pigs communicate with over 20 different vocalizations. Porkbun communicates with great customer service.",
      "Pigs don't sweat — they cool off in mud. Porkbun keeps their cool with low prices.",
      "The oldest known pig lived to be 24 years old. Your Porkbun domain can last even longer!",
    ];

    const oinks = [
      "OINK! 🐷",
      "Oink oink oink! (Translation: Great domain choice!)",
      "*happy pig noises*",
      "OINK OINK! (That means 'hello' in pig.)",
      "~oink~ Did someone say cheap domains?",
      "*snort* *oink* *snort snort*",
    ];

    const commands: Record<string, () => string> = {
      'HELP': () => [
        'Available commands:',
        '  HELP      — Show this list',
        '  OINK      — Make pig sounds',
        '  FACT      — Random pig fact',
        '  DOMAINS   — Check domain prices',
        '  REGISTER  — Register a domain',
        '  WHOAMI    — System identity',
        '  WEATHER   — Current barnyard weather',
        '  CLEAR     — Clear terminal',
        '  ABOUT     — About PORK-OS',
        '  CREDITS   — Competition credits',
      ].join('\n'),

      'OINK': () => oinks[Math.floor(Math.random() * oinks.length)],

      'FACT': () => '🐷 ' + pigFacts[Math.floor(Math.random() * pigFacts.length)],

      'DOMAINS': () => [
        '╭─────────────────────────────────────╮',
        '│  PORKBUN DOMAIN PRICES              │',
        '│─────────────────────────────────────│',
        '│  .com     $10.28/yr  ★ Popular      │',
        '│  .dev     $12.28/yr  ★ For devs     │',
        '│  .io      $33.28/yr  ★ Startups     │',
        '│  .pig     PRICELESS  ★ If only...   │',
        '│─────────────────────────────────────│',
        '│  Visit porkbun.com for all TLDs!    │',
        '╰─────────────────────────────────────╯',
      ].join('\n'),

      'REGISTER': () => [
        'REGISTER.EXE — Domain Registration Wizard',
        '',
        'Step 1: Think of a great name',
        'Step 2: Go to porkbun.com',
        'Step 3: Pay less than anywhere else',
        'Step 4: Profit! 🐷',
        '',
        'It\'s really that simple.',
      ].join('\n'),

      'WHOAMI': () => [
        'User: pork-os-user',
        'Role: Domain Enthusiast',
        'Shell: /bin/oink',
        'Home: /home/barn',
        'Registrar: Porkbun (obviously)',
      ].join('\n'),

      'WEATHER': () => {
        const conditions = ['Sunny with a chance of bacon', 'Partly cloudy with light oinking', 'Mud bath weather — perfect!', 'Clear skies over the domain barn', 'Warm and cozy — great day to register a .com'];
        return '🌤️ Barnyard Weather Report: ' + conditions[Math.floor(Math.random() * conditions.length)];
      },

      'ABOUT': () => [
        'PORK-OS v1.0 — "Snout Edition"',
        '',
        'A creative reimagining of the Porkbun pig mascot',
        'as a retro operating system interface.',
        '',
        'Built for the Porkbun Creative Competition 2026.',
        'Powered by Basement OS (basementos.com).',
        '',
        'All original work. Made with love and pig puns.',
      ].join('\n'),

      'CREDITS': () => [
        '╭─────────────────────────────────────╮',
        '│        PORK-OS CREDITS              │',
        '│─────────────────────────────────────│',
        '│  Concept & Code .. CloudStrife7     │',
        '│  Platform ........ Basement OS      │',
        '│  Inspiration ..... Porkbun LLC      │',
        '│  Framework ....... Astro            │',
        '│  Pig Puns ........ Unlimited        │',
        '│  Entry ........... Porkbun Creative │',
        '│                    Competition 2026 │',
        '╰─────────────────────────────────────╯',
      ].join('\n'),
    };

    function addOutput(text: string) {
      const lines = text.split('\n');
      for (const line of lines) {
        const p = document.createElement('p');
        p.textContent = line || '\u00A0';
        termOutput.appendChild(p);
      }
      termOutput.scrollTop = termOutput.scrollHeight;
    }

    termInput.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key !== 'Enter') return;
      const raw = termInput.value.trim();
      if (!raw) return;

      // Echo command
      addOutput(`C:\\PORK> ${raw}`);
      termInput.value = '';

      const cmd = raw.toUpperCase();

      if (cmd === 'CLEAR') {
        termOutput.innerHTML = '<p>Terminal cleared.</p><p>&nbsp;</p>';
        return;
      }

      if (commands[cmd]) {
        addOutput(commands[cmd]());
      } else {
        addOutput(`'${raw}' is not recognized as a PORK-OS command.`);
        addOutput('Type HELP for available commands.');
      }
      addOutput('');
    });

    // ─── SOCIAL TABS ───
    const socialTabs = document.querySelectorAll('.social-tab');
    socialTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = (tab as HTMLElement).dataset.tab;
        if (!target) return;
        socialTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        document.querySelectorAll('.social-feed').forEach(f => {
          (f as HTMLElement).style.display = 'none';
        });
        const feed = document.getElementById(`feed-${target}`);
        if (feed) feed.style.display = 'block';
      });
    });

    // ─── CHATBOT ───
    const chatFab = document.getElementById('chatbot-fab');
    const chatWindow = document.getElementById('chatbot-window');
    const chatClose = document.getElementById('chat-close');
    const chatInput = document.getElementById('chat-input') as HTMLInputElement | null;
    const chatSend = document.getElementById('chat-send');
    const chatBody = document.getElementById('chat-body');
    const fabBadge = document.getElementById('fab-badge');

    if (chatFab && chatWindow && chatClose && chatInput && chatSend && chatBody) {
      let chatOpen = false;

      chatFab.addEventListener('click', () => {
        chatOpen = !chatOpen;
        chatWindow.style.display = chatOpen ? 'flex' : 'none';
        if (chatOpen) {
          chatInput.focus();
          if (fabBadge) fabBadge.style.display = 'none';
        }
      });

      chatClose.addEventListener('click', () => {
        chatOpen = false;
        chatWindow.style.display = 'none';
      });

      // Domain name brainstormer logic
      const tlds = ['.com', '.dev', '.io', '.app', '.xyz', '.gg', '.co', '.me', '.site', '.fun', '.lol', '.wtf'];
      const prefixes = ['my', 'the', 'get', 'try', 'go', 'hey', 'just', 'super', 'mega', 'ultra'];
      const suffixes = ['hub', 'lab', 'zone', 'hq', 'spot', 'base', 'nest', 'den', 'pad', 'box'];
      const pigPuns = ['oink', 'snout', 'trotter', 'piglet', 'pork', 'ham', 'bacon', 'truffle'];

      function generateDomains(input: string): string[] {
        const words = input.toLowerCase().replace(/[^a-z0-9\s]/g, '').split(/\s+/).filter(w => w.length > 2);
        const domains: string[] = [];

        if (words.length === 0) {
          // Random fun suggestions
          for (let i = 0; i < 5; i++) {
            const pre = prefixes[Math.floor(Math.random() * prefixes.length)];
            const pig = pigPuns[Math.floor(Math.random() * pigPuns.length)];
            const tld = tlds[Math.floor(Math.random() * tlds.length)];
            domains.push(`${pre}${pig}${tld}`);
          }
          return domains;
        }

        // Word-based suggestions
        const mainWord = words[0];
        const secondWord = words.length > 1 ? words[1] : '';

        // Direct combos
        const combo = secondWord ? mainWord + secondWord : mainWord;
        domains.push(combo + tlds[Math.floor(Math.random() * tlds.length)]);

        // With prefix
        const pre = prefixes[Math.floor(Math.random() * prefixes.length)];
        domains.push(pre + mainWord + tlds[Math.floor(Math.random() * tlds.length)]);

        // With suffix
        const suf = suffixes[Math.floor(Math.random() * suffixes.length)];
        domains.push(mainWord + suf + tlds[Math.floor(Math.random() * tlds.length)]);

        // Pig pun version
        const pig = pigPuns[Math.floor(Math.random() * pigPuns.length)];
        domains.push(mainWord + pig + tlds[Math.floor(Math.random() * tlds.length)]);

        // Creative mashup
        if (secondWord) {
          domains.push(secondWord + mainWord + tlds[Math.floor(Math.random() * tlds.length)]);
        } else {
          domains.push(mainWord + 'ly' + tlds[Math.floor(Math.random() * tlds.length)]);
        }

        return domains;
      }

      const responses = [
        "Oink! Great idea! Here are some domain names I sniffed out:",
        "Oh, I LOVE that! My snout is tingling with ideas:",
        "*excited pig noises* Here's what I've got:",
        "Ooh, fancy! Let me dig through the truffle patch of domains:",
        "Now we're cooking with bacon! Check these out:",
      ];

      function addChatMsg(text: string, isBot: boolean) {
        const msg = document.createElement('div');
        msg.className = `chat-msg ${isBot ? 'bot' : 'user'}`;
        const bubble = document.createElement('div');
        bubble.className = 'chat-bubble';
        bubble.innerHTML = text;
        msg.appendChild(bubble);
        chatBody.appendChild(msg);
        chatBody.scrollTop = chatBody.scrollHeight;
      }

      function handleChat() {
        const input = chatInput.value.trim();
        if (!input) return;

        addChatMsg(input, false);
        chatInput.value = '';

        // Typing delay
        setTimeout(() => {
          const domains = generateDomains(input);
          const response = responses[Math.floor(Math.random() * responses.length)];
          const domainHtml = domains.map(d => `<span class="domain-suggestion">&#9734; ${d}</span>`).join('');
          addChatMsg(`${response}<br>${domainHtml}<br><em>Check availability at porkbun.com!</em>`, true);
        }, 600 + Math.random() * 400);
      }

      chatSend.addEventListener('click', handleChat);
      chatInput.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter') handleChat();
      });
    }
  });
</script>
