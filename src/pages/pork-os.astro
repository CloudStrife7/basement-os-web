<style>
  /* ═══════════════════════════════════════════════
     PORK-OS — Self-contained theme
     Pig-pink retro terminal aesthetic
  ═══════════════════════════════════════════════ */

  :root {
    --pork-bg: #0a0808;
    --pork-bg-secondary: #140e0e;
    --pork-pink: #ff6b9d;
    --pork-pink-dim: #cc5580;
    --pork-pink-glow: rgba(255, 107, 157, 0.4);
    --pork-hot: #ff3e8a;
    --pork-coral: #ff8fab;
    --pork-gold: #ffd700;
    --pork-text: #f0e0e4;
    --pork-text-dim: #9a8088;
    --pork-border: #3a2028;
    --pork-font: 'JetBrains Mono', 'VT323', 'Courier New', monospace;
  }

  .pork-os-wrapper {
    min-height: 100vh;
    background: var(--pork-bg);
    color: var(--pork-text);
    font-family: var(--pork-font);
    font-size: 14px;
    line-height: 1.6;
  }

  /* ─── BOOT SCREEN ─── */
  .boot-screen {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    position: relative;
    overflow: hidden;
  }

  .boot-screen::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.15) 2px,
      rgba(0, 0, 0, 0.15) 4px
    );
    animation: scanline-drift 8s linear infinite;
  }

  @keyframes scanline-drift {
    0% { transform: translateY(0); }
    100% { transform: translateY(4px); }
  }

  .boot-content {
    text-align: center;
    z-index: 1;
    position: relative;
    max-width: 700px;
    padding: 20px;
  }

  .boot-ascii {
    color: var(--pork-pink);
    font-size: 0.5em;
    line-height: 1.1;
    margin-bottom: 30px;
    opacity: 0;
    animation: boot-pig-in 1s ease-out 0.2s forwards;
  }

  @keyframes boot-pig-in {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }

  .pig-glow {
    text-shadow:
      0 0 5px var(--pork-pink-glow),
      0 0 15px var(--pork-pink-glow),
      0 0 30px rgba(255, 107, 157, 0.15);
  }

  .boot-text {
    text-align: left;
    max-width: 500px;
    margin: 0 auto;
  }

  .boot-line {
    color: var(--pork-coral);
    font-size: 0.85em;
    margin: 2px 0;
    opacity: 0;
    animation: boot-line-in 0.3s ease forwards;
    text-shadow: 0 0 3px var(--pork-pink-glow);
  }

  .blink-line {
    color: var(--pork-gold);
  }

  @keyframes boot-line-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .boot-line.visible.blink-line {
    animation: boot-line-in 0.3s ease forwards, blink 1s step-end infinite 0.3s;
  }

  /* ─── TERMINAL CHROME ─── */
  .pork-terminal {
    max-width: 900px;
    margin: 0 auto;
    padding: 20px;
    animation: terminal-in 0.6s ease;
  }

  @keyframes terminal-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .terminal-chrome {
    border: 1px solid var(--pork-border);
    background: var(--pork-bg);
    box-shadow:
      0 0 40px rgba(255, 107, 157, 0.08),
      inset 0 0 60px rgba(0, 0, 0, 0.3);
    position: relative;
  }

  .terminal-chrome::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 10;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.06) 2px,
      rgba(0, 0, 0, 0.06) 4px
    );
    animation: scanline-drift 8s linear infinite;
  }

  .chrome-bar {
    display: flex;
    align-items: center;
    padding: 10px 15px;
    background: var(--pork-bg-secondary);
    border-bottom: 1px solid var(--pork-border);
  }

  .chrome-dots {
    display: flex;
    gap: 8px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .dot:hover { opacity: 0.7; }
  .dot-close { background: #ff5f56; }
  .dot-min { background: #ffbd2e; }
  .dot-max { background: #27c93f; }

  .chrome-title {
    flex: 1;
    text-align: center;
    color: var(--pork-pink);
    font-weight: bold;
    font-size: 0.85em;
    letter-spacing: 2px;
    text-shadow: 0 0 8px var(--pork-pink-glow);
  }

  .chrome-right {
    display: flex;
    align-items: center;
  }

  .back-link {
    color: var(--pork-text-dim);
    text-decoration: none;
    font-size: 0.7em;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--pork-pink);
  }

  .terminal-body {
    padding: 30px;
    position: relative;
    z-index: 1;
  }

  /* ─── WELCOME ─── */
  .welcome-section {
    text-align: center;
    margin-bottom: 20px;
  }

  .pig-ascii-main {
    color: var(--pork-pink);
    font-size: 0.65em;
    line-height: 1.15;
    display: inline-block;
    text-shadow: 0 0 5px var(--pork-pink-glow);
  }

  .tagline {
    color: var(--pork-coral);
    font-size: 0.9em;
    margin-top: 10px;
    font-style: italic;
    text-shadow: 0 0 5px var(--pork-pink-glow);
  }

  /* ─── SHARED ─── */
  .separator {
    color: var(--pork-border);
    text-align: center;
    margin: 25px 0;
    font-size: 0.8em;
    overflow: hidden;
  }

  .separator-sm {
    color: var(--pork-border);
    display: block;
    text-align: center;
  }

  .info-card {
    margin: 20px 0;
  }

  .info-card h3 {
    color: var(--pork-pink);
    font-size: 0.9em;
    margin-bottom: 15px;
    text-shadow: 0 0 5px var(--pork-pink-glow);
  }

  .highlight {
    color: var(--pork-pink);
    font-weight: bold;
  }

  .cmd-highlight {
    color: var(--pork-gold);
    font-weight: bold;
  }

  /* ─── MASCOT ─── */
  .mascot-display {
    display: flex;
    gap: 30px;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .pig-art {
    color: var(--pork-pink);
    font-size: 0.75em;
    line-height: 1.2;
    flex-shrink: 0;
    text-shadow: 0 0 5px var(--pork-pink-glow);
  }

  .mascot-info {
    flex: 1;
    min-width: 250px;
  }

  .system-msg {
    color: var(--pork-text-dim);
    font-size: 0.85em;
    margin: 4px 0;
  }

  /* ─── GALLERY ─── */
  .pig-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
  }

  .gallery-item {
    text-align: center;
  }

  .gallery-frame {
    background: rgba(255, 107, 157, 0.03);
    border: 1px solid var(--pork-border);
    padding: 10px;
    transition: all 0.3s ease;
  }

  .gallery-frame:hover {
    border-color: var(--pork-pink-dim);
    box-shadow: 0 0 15px rgba(255, 107, 157, 0.1);
  }

  .mini-pig {
    color: var(--pork-pink);
    font-size: 0.65em;
    line-height: 1.2;
    text-shadow: 0 0 3px var(--pork-pink-glow);
  }

  .gallery-label {
    display: block;
    color: var(--pork-coral);
    font-size: 0.7em;
    margin-top: 8px;
    letter-spacing: 2px;
  }

  /* ─── INTERACTIVE TERMINAL ─── */
  .interactive-terminal {
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid var(--pork-border);
    padding: 15px;
    max-height: 300px;
    display: flex;
    flex-direction: column;
  }

  .term-output {
    flex: 1;
    overflow-y: auto;
    margin-bottom: 10px;
    max-height: 220px;
  }

  .term-output p {
    margin: 1px 0;
    font-size: 0.85em;
    color: var(--pork-coral);
  }

  .term-input-row {
    display: flex;
    align-items: center;
    gap: 8px;
    border-top: 1px solid var(--pork-border);
    padding-top: 10px;
  }

  .prompt-text {
    color: var(--pork-pink);
    font-weight: bold;
    white-space: nowrap;
    text-shadow: 0 0 3px var(--pork-pink-glow);
  }

  .term-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--pork-text);
    font-family: var(--pork-font);
    font-size: 0.85em;
    outline: none;
    caret-color: var(--pork-pink);
  }

  /* ─── MANIFESTO ─── */
  .manifesto {
    color: var(--pork-text);
    font-size: 0.85em;
