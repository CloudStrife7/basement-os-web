---
export interface TourMission {
  id: string;
  title: string;
  date: string;
  location: string;
  status: 'mission-complete' | 'in-progress' | 'upcoming';
  debrief: boolean;
  coverPhoto: string;
  photos: string[];
  description?: string;
}

interface Props {
  mission: TourMission;
}

const { mission } = Astro.props;

const statusLabel = {
  'mission-complete': 'MISSION COMPLETE',
  'in-progress': 'IN PROGRESS',
  'upcoming': 'INCOMING',
}[mission.status];
---

<article
  class={`tour-mission tour-mission--${mission.status}`}
  data-mission-id={mission.id}
  role="button"
  tabindex="0"
  aria-label={`Open photobooth for ${mission.title}`}
>
  <div class="tour-mission-photo-wrap">
    <img
      class="tour-mission-photo"
      src={mission.coverPhoto}
      alt={mission.title}
      loading="lazy"
    />
  </div>

  <!-- Top badges -->
  <div class="tour-top-bar">
    {mission.debrief && (
      <span class="tour-badge tour-badge--debrief">◈ DEBRIEF COMPLETE</span>
    )}
    <div class="tour-top-right">
      <span class="tour-date">{mission.date}</span>
      <span class={`tour-badge tour-badge--status tour-badge--${mission.status}`}>
        ● {statusLabel}
      </span>
    </div>
  </div>

  <!-- Bottom overlay text -->
  <div class="tour-overlay">
    <div class="tour-text">
      <h3 class="tour-title">{mission.title}</h3>
      <p class="tour-location">{mission.location}</p>
    </div>
    <div class="tour-cta">
      <span class="tour-cta-label">[ OPEN PHOTOBOOTH ]</span>
    </div>
  </div>
</article>
